# For fast shared testing, point either DATABASE_URL or RAILWAY_TEST_DATABASE_URL
# at the same Railway test Postgres instance used by the deployed API.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/airmentor
RAILWAY_TEST_DATABASE_URL=
PORT=4000
HOST=127.0.0.1
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173
SESSION_COOKIE_NAME=airmentor_session
CSRF_SECRET=change-me-before-production-like-deploys
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
SESSION_TTL_HOURS=168
DEFAULT_THEME_MODE=frosted-focus-light
AIRMENTOR_TELEMETRY_SINK_URL=
AIRMENTOR_TELEMETRY_SINK_BEARER_TOKEN=
# Frontend telemetry can point at the backend relay route, for example:
# VITE_AIRMENTOR_TELEMETRY_SINK_URL=https://api.example.com/api/client-telemetry
