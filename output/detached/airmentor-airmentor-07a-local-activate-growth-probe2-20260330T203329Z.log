[2026-03-30T20:33:29Z] command=zsh -lc $'cd air-mentor-api && CI=1 npx tsx <<\'TS\'\nimport { eq } from "drizzle-orm"\nimport { createTestApp, loginAs, TEST_ORIGIN } from "./tests/helpers/test-app.ts"\nimport { studentAssessmentScores, studentAttendanceSnapshots, studentObservedSemesterStates, transcriptSubjectResults, transcriptTermResults } from "./src/db/schema.ts"\nimport { parseObservedStateRow } from "./src/lib/proof-observed-state.ts"\nimport { PROOF_TERM_DEFS } from "./src/lib/msruas-proof-sandbox.ts"\n\nconst current = await createTestApp()\ntry {\n  const adminLogin = await loginAs(current.app, "sysadmin", "admin1234")\n  const dashboardBefore = await current.app.inject({ method: "GET", url: "/api/admin/batches/batch_branch_mnc_btech_2023/proof-dashboard", headers: { cookie: adminLogin.cookie } })\n  const activeRunId = dashboardBefore.json().activeRunDetail?.simulationRunId\n  const observedRows = await current.db.select().from(studentObservedSemesterStates).where(eq(studentObservedSemesterStates.simulationRunId, activeRunId))\n  const proofStudentIds = new Set(observedRows.map(row => row.studentId))\n  const proofOfferingIds = new Set(observedRows.map(row => {\n    const payload = parseObservedStateRow(row)\n    return typeof payload.offeringId === "string" && payload.offeringId.length > 0 ? payload.offeringId : null\n  }).filter((value): value is string => value != null))\n  const proofTermIds = new Set(PROOF_TERM_DEFS.map(term => term.termId))\n\n  async function countsFor(label) {\n    const transcriptRows = (await current.db.select().from(transcriptTermResults)).filter(row => proofStudentIds.has(row.studentId) && proofTermIds.has(row.termId))\n    const transcriptIds = new Set(transcriptRows.map(row => row.transcriptTermResultId))\n    const transcriptSubjectCount = (await current.db.select().from(transcriptSubjectResults)).filter(row => transcriptIds.has(row.transcriptTermResultId)).length\n    const attendanceCount = (await current.db.select().from(studentAttendanceSnapshots)).filter(row => proofStudentIds.has(row.studentId) && proofOfferingIds.has(row.offeringId) && row.source.startsWith("proof-run:")).length\n    const assessmentCount = (await current.db.select().from(studentAssessmentScores)).filter(row => proofStudentIds.has(row.studentId) && proofOfferingIds.has(row.offeringId) && row.termId === "term_mnc_sem6").length\n    console.log(label, JSON.stringify({ transcriptTermCount: transcriptRows.length, transcriptSubjectCount, attendanceCount, assessmentCount }))\n  }\n\n  await countsFor("before")\n  for (const semesterNumber of [4, 6, 4, 6]) {\n    const response = await current.app.inject({ method: "POST", url: `/api/admin/proof-runs/${activeRunId}/activate-semester`, headers: { cookie: adminLogin.cookie, origin: TEST_ORIGIN }, payload: { semesterNumber } })\n    console.log(`activate-${semesterNumber}`, response.statusCode, response.body)\n    await countsFor(`after-${semesterNumber}`)\n  }\n} finally {\n  await current.close()\n}\nTS' 
