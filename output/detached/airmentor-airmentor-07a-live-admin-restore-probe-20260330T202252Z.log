[2026-03-30T20:22:54Z] command=zsh -lc $'export PLAYWRIGHT_APP_URL=https://raed2180416.github.io/AirMentor/ PLAYWRIGHT_API_URL=https://api-production-ab72.up.railway.app/ AIRMENTOR_LIVE_SYSTEM_ADMIN_IDENTIFIER=sysadmin AIRMENTOR_LIVE_SYSTEM_ADMIN_PASSWORD=admin1234\nnode --input-type=module <<\'NODE\'\nimport assert from "node:assert/strict"\n\nconst api = process.env.PLAYWRIGHT_API_URL\nconst app = process.env.PLAYWRIGHT_APP_URL\nconst origin = new URL(app).origin\nconst identifier = process.env.AIRMENTOR_LIVE_SYSTEM_ADMIN_IDENTIFIER\nconst password = process.env.AIRMENTOR_LIVE_SYSTEM_ADMIN_PASSWORD\n\nconst loginResponse = await fetch(new URL("/api/session/login", api), {\n  method: "POST",\n  headers: { origin, "content-type": "application/json" },\n  body: JSON.stringify({ identifier, password }),\n})\nconst loginBody = await loginResponse.json()\nconst setCookies = typeof loginResponse.headers.getSetCookie === "function"\n  ? loginResponse.headers.getSetCookie()\n  : [loginResponse.headers.get("set-cookie")].filter(Boolean)\nconst cookieHeader = setCookies.map(value => value.split(";", 1)[0]).join("; ")\nconst csrfToken = loginBody?.csrfToken\nassert.equal(loginResponse.status, 200, `login failed: ${JSON.stringify(loginBody)}`)\nassert(cookieHeader.includes("airmentor_session="))\nassert.equal(typeof csrfToken, "string")\n\nconst headers = { origin, cookie: cookieHeader, "content-type": "application/json", "x-airmentor-csrf": csrfToken }\nconst dashboardResponse = await fetch(new URL("/api/admin/batches/batch_branch_mnc_btech_2023/proof-dashboard", api), { headers: { origin, cookie: cookieHeader } })\nconst dashboard = await dashboardResponse.json()\nconsole.log("dashboard-status", dashboardResponse.status)\nconsole.log("active-run", JSON.stringify({ simulationRunId: dashboard?.activeRunDetail?.simulationRunId, activeOperationalSemester: dashboard?.activeRunDetail?.activeOperationalSemester }))\nconst runId = dashboard?.activeRunDetail?.simulationRunId\nassert.equal(typeof runId, "string", "expected active run")\n\nfor (const semesterNumber of [4, 6]) {\n  const response = await fetch(new URL(`/api/admin/proof-runs/${encodeURIComponent(runId)}/activate-semester`, api), {\n    method: "POST",\n    headers,\n    body: JSON.stringify({ semesterNumber }),\n  })\n  const text = await response.text()\n  console.log(`activate-${semesterNumber}-status`, response.status)\n  console.log(`activate-${semesterNumber}-body`, text.slice(0, 1200))\n}\nNODE' 
