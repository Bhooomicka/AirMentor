[2026-03-30T20:40:11Z] command=zsh -lc $'export PLAYWRIGHT_APP_URL=https://raed2180416.github.io/AirMentor/ PLAYWRIGHT_API_URL=https://api-production-ab72.up.railway.app/ AIRMENTOR_LIVE_SYSTEM_ADMIN_IDENTIFIER=sysadmin AIRMENTOR_LIVE_SYSTEM_ADMIN_PASSWORD=admin1234\nnode --input-type=module <<\'NODE\'\nimport assert from "node:assert/strict"\n\nconst api = process.env.PLAYWRIGHT_API_URL\nconst app = process.env.PLAYWRIGHT_APP_URL\nconst origin = new URL(app).origin\nconst identifier = process.env.AIRMENTOR_LIVE_SYSTEM_ADMIN_IDENTIFIER\nconst password = process.env.AIRMENTOR_LIVE_SYSTEM_ADMIN_PASSWORD\nconst batchId = "batch_branch_mnc_btech_2023"\n\nconst loginResponse = await fetch(new URL("/api/session/login", api), {\n  method: "POST",\n  headers: { origin, "content-type": "application/json" },\n  body: JSON.stringify({ identifier, password }),\n})\nconst loginBody = await loginResponse.clone().json()\nassert.equal(loginResponse.status, 200, `login failed: ${loginResponse.status}`)\nconst setCookies = typeof loginResponse.headers.getSetCookie === "function"\n  ? loginResponse.headers.getSetCookie()\n  : [loginResponse.headers.get("set-cookie")].filter(Boolean)\nconst cookieHeader = setCookies.map(value => value.split(";", 1)[0]).join("; ")\nconst csrfToken = loginBody?.csrfToken\nconst headers = { origin, cookie: cookieHeader, "content-type": "application/json", "x-airmentor-csrf": csrfToken }\n\nasync function readDashboard() {\n  const response = await fetch(new URL(`/api/admin/batches/${batchId}/proof-dashboard`, api), { headers: { origin, cookie: cookieHeader } })\n  const text = await response.text()\n  console.log("dashboard-status", response.status)\n  console.log("dashboard-body", text.slice(0, 800))\n  assert.equal(response.status, 200, "dashboard read should succeed")\n  return JSON.parse(text)\n}\n\nasync function activate(runId, semesterNumber) {\n  const response = await fetch(new URL(`/api/admin/proof-runs/${runId}/activate-semester`, api), {\n    method: "POST",\n    headers,\n    body: JSON.stringify({ semesterNumber }),\n  })\n  const text = await response.text()\n  console.log(`activate-${semesterNumber}-status`, response.status)\n  console.log(`activate-${semesterNumber}-body`, text.slice(0, 1200))\n  return { status: response.status, bodyText: text }\n}\n\nconst before = await readDashboard()\nconst runId = before?.activeRunDetail?.simulationRunId\nconst original = before?.activeRunDetail?.activeOperationalSemester\nassert.equal(typeof runId, "string", "expected active run id")\nassert.equal(typeof original, "number", "expected active operational semester")\nconsole.log("before-state", JSON.stringify({ runId, original }))\n\nif (original !== 4) {\n  const toFour = await activate(runId, 4)\n  assert.equal(toFour.status, 200, "semester toggle to 4 should succeed on live backend")\n  const after4 = await readDashboard()\n  console.log("after-4-state", JSON.stringify({ activeOperationalSemester: after4?.activeRunDetail?.activeOperationalSemester }))\n}\n\nconst restore = await activate(runId, original)\nassert.equal(restore.status, 200, "semester restore should succeed on live backend")\nconst afterRestore = await readDashboard()\nconsole.log("after-restore-state", JSON.stringify({ activeOperationalSemester: afterRestore?.activeRunDetail?.activeOperationalSemester, restoreStatus: restore.status }))\nNODE' 
