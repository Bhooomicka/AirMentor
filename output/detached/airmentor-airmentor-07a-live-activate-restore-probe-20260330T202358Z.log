iveRunDetail?.simulationRunId\\nassert.equal(typeof runId, "string", "expected active run")\\n\\nfor (const semesterNumber of [4, 6]) {\\n  const response = await fetch(new URL(`/api/admin/proof-runs/${encodeURIComponent(runId)}/activate-semester`, api), {\\n    method: "POST",\\n    headers: authHeaders,\\n    body: JSON.stringify({ semesterNumber }),\\n  })\\n  const text = await response.text()\\n  console.log("activate", semesterNumber, response.status, text.slice(0, 500))\\n}\\n\\nconst dashboardAfter = await fetch(dashboardUrl, { headers: { origin, cookie: cookieHeader } })\\nconst dashboardAfterBody = await dashboardAfter.json()\\nconsole.log("dashboard-after", dashboardAfter.status, JSON.stringify({ run: dashboardAfterBody?.activeRunDetail?.simulationRunId, semester: dashboardAfterBody?.activeRunDetail?.activeOperationalSemester }))\\nNODE' 
