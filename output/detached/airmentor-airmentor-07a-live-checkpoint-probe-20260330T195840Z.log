i/academic/bootstrap", api)\nbootstrapUrl.searchParams.set("simulationStageCheckpointId", checkpointId)\nconst bootstrapResponse = await fetch(bootstrapUrl, { headers: { origin, cookie } })\nconst bootstrapText = await bootstrapResponse.text()\nconsole.log("bootstrap-status", bootstrapResponse.status)\nconsole.log("bootstrap-body", bootstrapText.slice(0, 800))\nassert.equal(bootstrapResponse.status, 200, "academic bootstrap should accept the target checkpoint")\nconst bootstrap = JSON.parse(bootstrapText)\nassert.equal(bootstrap?.proofPlayback?.simulationStageCheckpointId, checkpointId, "bootstrap proofPlayback should preserve the target checkpoint")\n\nconst profileUrl = new URL(`/api/academic/faculty-profile/${encodeURIComponent(facultyId)}`, api)\nprofileUrl.searchParams.set("simulationStageCheckpointId", checkpointId)\nconst profileResponse = await fetch(profileUrl, { headers: { origin, cookie } })\nconst profileText = await profileResponse.text()\nconsole.log("faculty-profile-status", profileResponse.status)\nconsole.log("faculty-profile-body", profileText.slice(0, 800))\nassert.equal(profileResponse.status, 200, "faculty profile should accept the target checkpoint")\nconst profile = JSON.parse(profileText)\nassert.equal(profile?.selectedCheckpoint?.simulationStageCheckpointId, checkpointId, "faculty profile should preserve selected checkpoint")\nassert.equal(profile?.activeRunContexts?.[0]?.simulationStageCheckpointId ?? profile?.activeRunContexts?.[0]?.simulationRunId ? typeof profile?.activeRunContexts?.[0]?.simulationRunId : "missing", "string", "faculty profile should expose an active run context")\nconsole.log("probe-ok", JSON.stringify({ checkpointId, facultyId, activeRunId: profile?.activeRunContexts?.[0]?.simulationRunId ?? null }))\nNODE' 
