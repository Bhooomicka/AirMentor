[2026-03-30T20:26:49Z] cwd=/home/raed/projects/air-mentor-ui
[2026-03-30T20:26:49Z] command=zsh -lc $'cd air-mentor-api && set -a && source .env && set +a && npx tsx <<\'TS\'\nimport { eq } from "drizzle-orm"\nimport { createPool, createDb } from "./src/db/client.ts"\nimport { simulationRuns, studentObservedSemesterStates, sectionOfferings, transcriptTermResults, studentAttendanceSnapshots, studentAssessmentScores } from "./src/db/schema.ts"\nimport { activateProofOperationalSemester } from "./src/lib/msruas-proof-control-plane.ts"\n\nconst pool = createPool(process.env.DATABASE_URL!)\nconst db = createDb(pool)\nconst runId = "sim_mnc_2023_first6_v1"\ntry {\n  const [run] = await db.select().from(simulationRuns).where(eq(simulationRuns.simulationRunId, runId))\n  console.log("run-before", JSON.stringify({ simulationRunId: run?.simulationRunId, activeFlag: run?.activeFlag, activeOperationalSemester: run?.activeOperationalSemester, semesterStart: run?.semesterStart, semesterEnd: run?.semesterEnd }))\n  const [observedRows, offeringRows, transcriptRows, attendanceRows, assessmentRows] = await Promise.all([\n    db.select().from(studentObservedSemesterStates).where(eq(studentObservedSemesterStates.simulationRunId, runId)),\n    db.select().from(sectionOfferings).where(eq(sectionOfferings.termId, "term_mnc_sem6")),\n    db.select().from(transcriptTermResults),\n    db.select().from(studentAttendanceSnapshots),\n    db.select().from(studentAssessmentScores),\n  ])\n  console.log("table-counts", JSON.stringify({ observed: observedRows.length, sem6Offerings: offeringRows.length, transcriptTermResults: transcriptRows.length, attendance: attendanceRows.length, assessment: assessmentRows.length }))\n\n  await db.transaction(async tx => {\n    try {\n      const result = await activateProofOperationalSemester(tx as any, {\n        simulationRunId: runId,\n        semesterNumber: 4,\n        actorFacultyId: "fac_sysadmin",\n        now: new Date().toISOString(),\n      })\n      console.log("activation-result", JSON.stringify(result))\n      throw new Error("ROLLBACK_AFTER_SUCCESS")\n    } catch (error) {\n      console.log("activation-error-name", error instanceof Error ? error.name : typeof error)\n      console.log("activation-error-message", error instanceof Error ? error.message : String(error))\n      console.log("activation-error-stack", error instanceof Error ? error.stack : String(error))\n      const candidate = error as any\n      if (candidate && typeof candidate === "object") {\n        console.log("activation-error-fields", JSON.stringify({ code: candidate.code ?? null, detail: candidate.detail ?? null, hint: candidate.hint ?? null, table: candidate.table ?? null, column: candidate.column ?? null, constraint: candidate.constraint ?? null, schema: candidate.schema ?? null, severity: candidate.severity ?? null }))\n      }\n      throw error\n    }\n  })\n} catch (error) {\n  if (error instanceof Error && error.message === "ROLLBACK_AFTER_SUCCESS") {\n    console.log("rolled-back-after-success")\n  } else {\n    console.log("outer-error", error instanceof Error ? error.stack : String(error))\n  }\n} finally {\n  await pool.end()\n}\nTS' 
