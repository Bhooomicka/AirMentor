[2026-03-30T20:42:44Z] cwd=/home/raed/projects/air-mentor-ui
[2026-03-30T20:42:44Z] command=zsh -lc $'cd air-mentor-api && set -a && source .env && set +a && npx tsx <<\'TS\'\nimport { sql } from "drizzle-orm"\nimport { createPool, createDb } from "./src/db/client.ts"\nimport { transcriptTermResults, students } from "./src/db/schema.ts"\n\nconst pool = createPool(process.env.DATABASE_URL!)\nconst db = createDb(pool)\ntry {\n  const total = await db.execute(sql`\n    select count(*)::int as count\n    from transcript_term_results t\n    join students s on s.student_id = t.student_id\n    where s.batch_id = batch_branch_mnc_btech_2023\n      and t.term_id in (term_mnc_sem1,term_mnc_sem2,term_mnc_sem3,term_mnc_sem4,term_mnc_sem5)\n  `)\n  const dupes = await db.execute(sql`\n    select t.student_id, t.term_id, count(*)::int as count\n    from transcript_term_results t\n    join students s on s.student_id = t.student_id\n    where s.batch_id = batch_branch_mnc_btech_2023\n      and t.term_id in (term_mnc_sem1,term_mnc_sem2,term_mnc_sem3,term_mnc_sem4,term_mnc_sem5)\n    group by t.student_id, t.term_id\n    having count(*) > 1\n    order by count(*) desc, t.student_id asc, t.term_id asc\n    limit 20\n  `)\n  const studentsCount = await db.execute(sql`\n    select count(*)::int as count\n    from students\n    where batch_id = batch_branch_mnc_btech_2023\n  `)\n  console.log(students, JSON.stringify(studentsCount.rows[0] ?? null))\n  console.log(total, JSON.stringify(total.rows[0] ?? null))\n  console.log(dupes, JSON.stringify(dupes.rows))\n} finally {\n  await pool.end()\n}\nTS' 
