rapUrl.searchParams.set("simulationStageCheckpointId", checkpointId)\nconst bootstrapResponse = await fetch(bootstrapUrl, { headers: { origin, cookie } })\nconst bootstrap = await bootstrapResponse.json()\nconsole.log("bootstrap-status", bootstrapResponse.status)\nconsole.log("bootstrap-proof-playback", JSON.stringify(bootstrap?.proofPlayback ?? null))\nassert.equal(bootstrapResponse.status, 200, "academic bootstrap should accept the target checkpoint")\nassert.equal(bootstrap?.proofPlayback?.simulationStageCheckpointId, checkpointId, "bootstrap proofPlayback should preserve the target checkpoint")\n\nconst profileUrl = new URL(`/api/academic/faculty-profile/${encodeURIComponent(facultyId)}`, api)\nprofileUrl.searchParams.set("simulationStageCheckpointId", checkpointId)\nconst profileResponse = await fetch(profileUrl, { headers: { origin, cookie } })\nconst profile = await profileResponse.json()\nconsole.log("faculty-profile-status", profileResponse.status)\nconsole.log("faculty-profile-proof-ops", JSON.stringify({\n  selectedCheckpoint: profile?.proofOperations?.selectedCheckpoint ?? null,\n  activeRunContext: profile?.proofOperations?.activeRunContexts?.[0] ?? null,\n}))\nassert.equal(profileResponse.status, 200, "faculty profile should accept the target checkpoint")\nassert.equal(profile?.proofOperations?.selectedCheckpoint?.simulationStageCheckpointId, checkpointId, "faculty profile should preserve selected checkpoint")\nassert.equal(typeof profile?.proofOperations?.activeRunContexts?.[0]?.simulationRunId, "string", "faculty profile should expose an active run context")\nconsole.log("probe-ok", JSON.stringify({ checkpointId, facultyId, activeRunId: profile?.proofOperations?.activeRunContexts?.[0]?.simulationRunId ?? null }))\nNODE' 
