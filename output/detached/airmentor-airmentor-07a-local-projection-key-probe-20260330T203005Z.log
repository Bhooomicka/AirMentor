payload: { semesterNumber: 4 } })\n  console.log("activate", response.statusCode)\n  const attendanceAfter = await current.db.select().from(studentAttendanceSnapshots)\n  const assessmentAfter = await current.db.select().from(studentAssessmentScores)\n  console.log("attendance-after-tail", JSON.stringify(attendanceAfter.slice(-3)))\n  console.log("assessment-after-tail", JSON.stringify(assessmentAfter.slice(-3)))\n} finally {\n  await current.close()\n}\nTS' 
