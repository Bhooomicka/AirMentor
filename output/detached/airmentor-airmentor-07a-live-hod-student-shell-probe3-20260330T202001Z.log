[2026-03-30T20:20:02Z] command=zsh -lc $'export PLAYWRIGHT_APP_URL=https://raed2180416.github.io/AirMentor/ PLAYWRIGHT_API_URL=https://api-production-ab72.up.railway.app/ AIRMENTOR_LIVE_TEACHER_IDENTIFIER=kavitha.rao\nnode --input-type=module <<\'NODE\'\nimport assert from "node:assert/strict"\n\nconst api = process.env.PLAYWRIGHT_API_URL\nconst app = process.env.PLAYWRIGHT_APP_URL\nconst origin = new URL(app).origin\nconst checkpointId = "stage_checkpoint_654335929a345857eab259b0"\nconst teacherIdentifier = process.env.AIRMENTOR_LIVE_TEACHER_IDENTIFIER?.trim() || "kavitha.rao"\nconst passwordCandidates = ["faculty1234", "1234"]\n\nasync function login(identifier, password) {\n  return fetch(new URL("/api/session/login", api), {\n    method: "POST",\n    headers: { origin, "content-type": "application/json" },\n    body: JSON.stringify({ identifier, password }),\n  })\n}\n\nlet loginResponse = null\nlet teachingPassword = null\nlet loginBody = null\nfor (const password of passwordCandidates) {\n  const response = await login(teacherIdentifier, password)\n  if (response.ok) {\n    loginResponse = response\n    teachingPassword = password\n    loginBody = await response.clone().json()\n    break\n  }\n}\nassert(loginResponse, `could not log in as ${teacherIdentifier}`)\nconst setCookies = typeof loginResponse.headers.getSetCookie === "function"\n  ? loginResponse.headers.getSetCookie()\n  : [loginResponse.headers.get("set-cookie")].filter(Boolean)\nconst cookieHeader = setCookies.map(value => value.split(";", 1)[0]).join("; ")\nassert(cookieHeader.includes("airmentor_session="), "expected session cookie after login")\nassert(cookieHeader.includes("airmentor_csrf="), "expected csrf cookie after login")\nconst csrfToken = loginBody?.csrfToken ?? null\nassert.equal(typeof csrfToken, "string", "expected login body csrfToken")\nconsole.log("teacher-login", loginResponse.status, teacherIdentifier, teachingPassword)\nconsole.log("cookie-header", cookieHeader)\n\nconst sessionResponse = await fetch(new URL("/api/session", api), { headers: { origin, cookie: cookieHeader } })\nassert.equal(sessionResponse.status, 200, "session should be readable after teacher login")\nconst session = await sessionResponse.json()\nconst hodGrantId = session?.availableRoleGrants?.find(grant => grant?.roleCode === "HOD")?.grantId\nassert.equal(typeof hodGrantId, "string", "expected HOD grant id in academic session")\nconsole.log("hod-grant", hodGrantId)\n\nconst authHeaders = { origin, cookie: cookieHeader, "content-type": "application/json", "x-airmentor-csrf": csrfToken }\nconst roleResponse = await fetch(new URL("/api/session/role-context", api), {\n  method: "POST",\n  headers: authHeaders,\n  body: JSON.stringify({ roleGrantId: hodGrantId }),\n})\nconst roleBody = await roleResponse.text()\nconsole.log("role-context-status", roleResponse.status)\nconsole.log("role-context-body", roleBody.slice(0, 400))\nassert.equal(roleResponse.status, 200, "expected HOD role switch to succeed")\n\nconst proofStudentsUrl = new URL("/api/academic/hod/proof-students", api)\nproofStudentsUrl.searchParams.set("simulationStageCheckpointId", checkpointId)\nconst proofStudentsResponse = await fetch(proofStudentsUrl, { headers: { origin, cookie: cookieHeader } })\nconst proofStudents = await proofStudentsResponse.json()\nconsole.log("proof-students-status", proofStudentsResponse.status)\nconsole.log("proof-students-count", proofStudents?.items?.length ?? null)\nassert.equal(proofStudentsResponse.status, 200, "HOD proof students should load for the checkpoint")\nassert((proofStudents?.items?.length ?? 0) > 0, "expected at least one HOD proof student for the checkpoint")\nconst studentId = proofStudents.items[0].studentId\nconsole.log("probe-student", studentId)\n\nfor (const [label, pathname] of [\n  ["student-shell-card", `/api/academic/student-shell/students/${encodeURIComponent(studentId)}/card`],\n  ["student-shell-timeline", `/api/academic/student-shell/students/${encodeURIComponent(studentId)}/timeline`],\n  ["risk-explorer", `/api/academic/students/${encodeURIComponent(studentId)}/risk-explorer`],\n]) {\n  const url = new URL(pathname, api)\n  url.searchParams.set("simulationStageCheckpointId", checkpointId)\n  const response = await fetch(url, { headers: { origin, cookie: cookieHeader } })\n  const body = await response.text()\n  console.log(`${label}-status`, response.status)\n  console.log(`${label}-body`, body.slice(0, 500))\n  assert.equal(response.status, 200, `${label} should accept the checkpoint-backed HOD request`)\n}\n\nconsole.log("probe-ok", JSON.stringify({ checkpointId, studentId }))\nNODE' 
