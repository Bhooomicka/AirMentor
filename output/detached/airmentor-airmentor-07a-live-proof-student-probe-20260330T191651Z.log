[2026-03-30T19:16:51Z] command=bash -lc $'node --input-type=module <<\'EOF\'\nconst apiUrl = "https://api-production-ab72.up.railway.app";\nconst origin = "https://raed2180416.github.io";\nconst login = await fetch(new URL("/api/session/login", apiUrl), {\n  method: "POST",\n  headers: { origin, "content-type": "application/json" },\n  body: JSON.stringify({ identifier: "sysadmin", password: "admin1234" }),\n});\nconst loginBody = await login.json();\nconst setCookie = login.headers.get("set-cookie") ?? "";\nconst csrfToken = loginBody.csrfToken;\nconst cookieHeader = setCookie.split(/, (?=[^;]+=[^;]+)/).map(part => part.split(";")[0]).join("; ");\nconst response = await fetch(new URL("/api/admin/students", apiUrl), {\n  headers: { origin, accept: "application/json", cookie: cookieHeader, "x-airmentor-csrf": csrfToken },\n});\nconst payload = await response.json();\nconst items = Array.isArray(payload.items) ? payload.items : [];\nconst proofStudents = items.filter(item => String(item.studentId || "").startsWith("mnc_student_") || String(item.usn || "").startsWith("1MS23MC"));\nconsole.log(JSON.stringify({ status: response.status, total: items.length, proofStudentCount: proofStudents.length, sample: proofStudents.slice(0, 3) }, null, 2));\nEOF' 
