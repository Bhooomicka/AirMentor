  afterEach(() => {
    vi.restoreAllMocks()
    process.env.NODE_ENV = originalNodeEnv
    process.env.AIRMENTOR_TELEMETRY_ENABLED = originalTelemetryEnabled
  })

  it('forwards structured backend events to the configured sink through the dispatch hook', async () => {
