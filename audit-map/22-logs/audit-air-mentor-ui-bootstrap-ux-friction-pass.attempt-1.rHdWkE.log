                  value={studentRegistrySearch}
                  onChange={setStudentRegistrySearch}
                  placeholder="Search student, USN, branch, section, email..."
                  ariaLabel="Student registry search"
                />
                <div style={{ display: 'flex', gap: 8, flexWrap: 'wrap' }}>
