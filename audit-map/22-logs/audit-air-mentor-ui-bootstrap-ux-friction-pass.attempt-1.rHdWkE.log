              {selectedBatchIsCanonicalProof ? `Pilot ${selectedBatch.batchLabel}` : `Current ${selectedBatch.batchLabel}`}
            </Chip>
            <Chip color={authoritativeSemesterChipColor}>{`${authoritativeSemesterSourceLabel} · ${authoritativeSemesterLabel}`}</Chip>
