                              variant="ghost"
                              dataProofAction="hod-open-student-shell"
                              dataProofEntityId={row.studentId}
                              onClick={() => onOpenStudentShell(row.studentId)}
                            >
                              Shell
                            </Btn>
                          </div>
                        </TD>
                      </tr>
                    )
                    })}
                  </tbody>
                </table>
              )}
            </TableCard>
          </div>
        ) : null}

        {activeTab === 'courses' ? (
