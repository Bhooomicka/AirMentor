    snapshot.offeringId ?? '',
    snapshot.uploadOfferingId ?? '',
    snapshot.uploadKind,
    snapshot.entryOfferingId,
    snapshot.entryKind,
    snapshot.selectedMenteeId ?? '',
    snapshot.historyProfile?.usn ?? '',
    snapshot.historyStudentId ?? '',
