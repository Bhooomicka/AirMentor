    void repositories.locksAudit.saveLocks(lockByOffering).catch(error => {
      hydratedLockSnapshotRef.current = previousSnapshot
      console.error('Could not persist lock state.', error)
    })
  }, [lockByOffering, repositories])
  useEffect(() => {
