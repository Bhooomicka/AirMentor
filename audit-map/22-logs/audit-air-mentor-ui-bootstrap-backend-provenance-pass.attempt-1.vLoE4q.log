   306	    .forEach(row => {
   307	      const featurePayload = parseJson(row.featureJson, null as ReturnType<typeof buildObservableFeaturePayload> | null)
   308	      const labelPayload = parseJson(row.labelJson, null as ObservableLabelPayload | null)
   309	      const sourceRefs = parseJson(row.sourceRefsJson, null as ObservableSourceRefs | null)
