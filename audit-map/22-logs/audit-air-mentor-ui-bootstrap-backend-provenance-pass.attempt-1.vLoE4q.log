  3080	        attendance: sectionCode === 'A' ? 82 : 74,
  3081	        studentCount: 60,
  3082	        stage: 2,
  3083	        stageLabel: 'TT1 Review',
  3084	        stageDescription: 'Observable monitoring window after TT1; reassessment stays active.',
  3085	        stageColor: '#f59e0b',
  3086	        tt1Done: 1,
  3087	        tt2Done: 0,
  3088	        tt1Locked: 1,
  3089	        tt2Locked: 0,
  3090	        quizLocked: 1,
  3091	        assignmentLocked: 1,
  3092	        pendingAction: 'Adaptive reassessment window active',
  3093	        status: 'active',
  3094	        version: 1,
  3095	        createdAt: now,
  3096	        updatedAt: now,
  3097	      })
  3098	      if (!ownershipRows.some(row => row.offeringId === offeringId && row.facultyId === faculty.facultyId && row.status === 'active')) {
  3099	        newOwnershipRows.push({
  3100	          ownershipId: `ownership_${faculty.facultyId}_${offeringId}`,
  3101	          offeringId,
  3102	          facultyId: faculty.facultyId,
  3103	          ownershipRole: 'owner',
  3104	          status: 'active',
  3105	          version: 1,
  3106	          createdAt: now,
  3107	          updatedAt: now,
  3108	        })
  3109	      }
  3110	      offeringFacultyById.set(offeringId, faculty.facultyId)
  3111	    })
  3112	  })
  3113	
  3114	  if (newOfferingRows.length > 0) await db.insert(sectionOfferings).values(newOfferingRows)
  3115	  if (newOwnershipRows.length > 0) await db.insert(facultyOfferingOwnerships).values(newOwnershipRows)
  3116	
  3117	  const refreshedOfferings = newOfferingRows.length > 0
  3118	    ? await db.select().from(sectionOfferings).where(eq(sectionOfferings.termId, 'term_mnc_sem6'))
  3119	    : offeringRows
  3120	  return {
  3121	    offerings: refreshedOfferings,
  3122	    offeringFacultyById,
  3123	  }
  3124	}
