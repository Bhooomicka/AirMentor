## air-mentor-api/src/db/migrate.ts
     1	import { readdir, readFile } from 'node:fs/promises'
     2	import path from 'node:path'
     3	import { fileURLToPath } from 'node:url'
     4	import { createPool } from './client.js'
     5	import { loadConfig } from '../config.js'
     6	
     7	async function ensureMigrationsTable(client: { query: (sql: string, params?: unknown[]) => Promise<unknown> }) {
     8	  await client.query(`
     9	    CREATE TABLE IF NOT EXISTS schema_migrations (
    10	      filename text PRIMARY KEY,
    11	      applied_at text NOT NULL
    12	    )
    13	  `)
    14	}
    15	
    16	export async function runSqlMigrations(client: { query: (sql: string, params?: unknown[]) => Promise<{ rows?: Array<{ filename: string }> }> }, migrationsDir: string) {
    17	  await ensureMigrationsTable(client)
    18	  const files = (await readdir(migrationsDir)).filter(file => file.endsWith('.sql')).sort()
    19	  for (const filename of files) {
    20	    const existing = await client.query('SELECT filename FROM schema_migrations WHERE filename = $1', [filename])
    21	    if (existing.rows && existing.rows.length > 0) continue
    22	    const sql = await readFile(path.join(migrationsDir, filename), 'utf8')
    23	    await client.query(sql)
    24	    await client.query('INSERT INTO schema_migrations (filename, applied_at) VALUES ($1, $2)', [filename, new Date().toISOString()])
    25	  }
    26	}
    27	
    28	export async function main() {
    29	  const config = loadConfig()
    30	  const pool = createPool(config.databaseUrl)
    31	  try {
    32	    const migrationsDir = path.join(path.dirname(fileURLToPath(import.meta.url)), 'migrations')
    33	    await runSqlMigrations(pool, migrationsDir)
    34	  } finally {
    35	    await pool.end()
    36	  }
    37	}
    38	
    39	const currentFilePath = fileURLToPath(import.meta.url)
    40	if (process.argv[1] && path.resolve(process.argv[1]) === currentFilePath) {
    41	  main().catch(error => {
    42	    console.error(error)
    43	    process.exitCode = 1
    44	  })
    45	}

