   254	      requestedActivate: Boolean(parseJson(run.progressJson, {} as Record<string, unknown>).requestedActivate ?? true),
   255	      mode: run.sourceType,
   256	      retryOf: run.simulationRunId,
   257	    } as Record<string, unknown>,
   258	  }
   259	}
