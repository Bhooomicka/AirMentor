   332	    .filter(row => row.effectiveTo === null)
   333	    .slice()
   334	    .sort((left, right) => left.facultyId.localeCompare(right.facultyId))
   335	    .forEach(row => {
   336	      if (mentorFacultyIdByStudentId.has(row.studentId)) return
   337	      mentorFacultyIdByStudentId.set(row.studentId, row.facultyId)
   338	    })
   339	  const hodFacultyId = grantRows
   340	    .filter(row => row.roleCode === 'HOD' && [run.batchId, MSRUAS_PROOF_BRANCH_ID, MSRUAS_PROOF_DEPARTMENT_ID].includes(row.scopeId))
   341	    .slice()
   342	    .sort((left, right) => left.facultyId.localeCompare(right.facultyId))[0]?.facultyId ?? null
   343	  const overloadPenaltyBySemesterFaculty = new Map<string, number>()
   344	  const currentSemesterLoads = teacherLoadRows.filter(row => row.semesterNumber === currentSemesterNumber)
   345	  const currentSemesterLoadAverage = deps.average(currentSemesterLoads.map(row => row.weeklyContactHours))
   346	  const currentSemesterOverloadThreshold = Math.max(8, Math.ceil(currentSemesterLoadAverage * 1.25))
   347	  currentSemesterLoads.forEach(row => {
   348	    overloadPenaltyBySemesterFaculty.set(row.facultyId, row.weeklyContactHours > currentSemesterOverloadThreshold ? 2 : 0)
   349	  })
   350	  const mentorAssignmentCountByFacultyId = new Map<string, number>()
   351	  mentorRows
   352	    .filter(row => row.effectiveTo === null)
   353	    .forEach(row => {
   354	      mentorAssignmentCountByFacultyId.set(row.facultyId, (mentorAssignmentCountByFacultyId.get(row.facultyId) ?? 0) + 1)
   355	    })
   356	  const supervisedSectionCount = new Set(
   357	    teacherAllocationRows
   358	      .filter(row => row.sectionCode != null)
   359	      .map(row => row.sectionCode!),
