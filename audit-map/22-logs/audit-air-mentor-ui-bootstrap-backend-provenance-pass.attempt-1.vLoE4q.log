    84	  const semesterNumber = activeTerm?.semesterNumber ?? batch.currentSemester
    85	  if (!activeTerm) {
    86	    return {
    87	      sectionCount: 0,
    88	      studentCount: 0,
    89	      facultyCount: 0,
    90	      semesterStart: semesterNumber,
    91	      semesterEnd: semesterNumber,
    92	      sourceType: 'live-runtime',
    93	      metrics: {
    94	        proofGoal: 'live-runtime-playback',
    95	        queueState: 'waiting-for-term',
    96	      },
    97	    }
    98	  }
    99	
   100	  const [offeringRows, enrollmentRows, ownershipRows] = await Promise.all([
   101	    db.select().from(sectionOfferings).where(eq(sectionOfferings.termId, activeTerm.termId)),
   102	    db.select().from(studentEnrollments).where(and(
   103	      eq(studentEnrollments.termId, activeTerm.termId),
   104	      eq(studentEnrollments.academicStatus, 'active'),
   105	    )),
   106	    db.select().from(facultyOfferingOwnerships).where(eq(facultyOfferingOwnerships.status, 'active')),
   107	  ])
   108	  const offeringIdSet = new Set(offeringRows.map(row => row.offeringId))
   109	  const sectionDistribution = Object.fromEntries(
   110	    Array.from(new Set(offeringRows.map(row => row.sectionCode))).map(sectionCode => [
   111	      sectionCode,
   112	      enrollmentRows.filter(row => row.sectionCode === sectionCode).length,
   113	    ]),
   114	  )
   115	
   116	  return {
   117	    sectionCount: new Set(offeringRows.map(row => row.sectionCode)).size,
   118	    studentCount: enrollmentRows.length,
   119	    facultyCount: new Set(ownershipRows.filter(row => row.offeringId != null && offeringIdSet.has(row.offeringId)).map(row => row.facultyId)).size,
   120	    semesterStart: semesterNumber,
   121	    semesterEnd: semesterNumber,
   122	    sourceType: 'live-runtime',
   123	    metrics: {
   124	      proofGoal: 'live-runtime-playback',
   125	      termId: activeTerm.termId,
   126	      sectionDistribution,
   127	    },
