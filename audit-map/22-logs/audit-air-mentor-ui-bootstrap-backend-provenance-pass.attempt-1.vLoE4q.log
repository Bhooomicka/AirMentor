  2887	  }
  2888	  const bridgeRowsByNodeId = new Map(bridgeRows.map(row => [row.curriculumNodeId, row]))
  2889	  const partitionsByNodeKind = new Map(partitionRows.map(row => [`${row.curriculumNodeId}::${row.partitionKind}`, row]))
  2890	
  2891	  const courses = nodeRows.map<RuntimeCourse>(row => ({
  2892	    curriculumNodeId: row.curriculumNodeId,
  2893	    semesterNumber: row.semesterNumber,
  2894	    courseId: row.courseId,
  2895	    courseCode: row.courseCode,
  2896	    title: row.title,
  2897	    credits: row.credits,
  2898	    internalCompilerId: row.internalCompilerId,
  2899	    officialWebCode: row.officialWebCode,
  2900	    officialWebTitle: row.officialWebTitle,
  2901	    matchStatus: row.matchStatus,
  2902	    mappingNote: row.mappingNote,
  2903	    assessmentProfile: row.assessmentProfile,
  2904	    explicitPrerequisites: [...(explicitSourcesByTarget.get(row.curriculumNodeId) ?? [])].sort(),
  2905	    addedPrerequisites: [...(addedSourcesByTarget.get(row.curriculumNodeId) ?? [])].sort(),
  2906	    bridgeModules: parseJson(bridgeRowsByNodeId.get(row.curriculumNodeId)?.moduleTitlesJson ?? '[]', [] as string[]),
  2907	    tt1Topics: parseJson(partitionsByNodeKind.get(`${row.curriculumNodeId}::tt1`)?.topicsJson ?? '[]', [] as string[]),
  2908	    tt2Topics: parseJson(partitionsByNodeKind.get(`${row.curriculumNodeId}::tt2`)?.topicsJson ?? '[]', [] as string[]),
  2909	    seeTopics: parseJson(partitionsByNodeKind.get(`${row.curriculumNodeId}::see`)?.topicsJson ?? '[]', [] as string[]),
  2910	    workbookTopics: parseJson(partitionsByNodeKind.get(`${row.curriculumNodeId}::workbook`)?.topicsJson ?? '[]', [] as string[]),
  2911	  })).sort((left, right) => left.semesterNumber - right.semesterNumber || left.internalCompilerId.localeCompare(right.internalCompilerId))
  2912	
  2913	  const optionsByBasketId = new Map<string, Array<typeof electiveOptions.$inferSelect>>()
  2914	  for (const option of optionRows) {
  2915	    optionsByBasketId.set(option.electiveBasketId, [...(optionsByBasketId.get(option.electiveBasketId) ?? []), option])
  2916	  }
  2917	  const electives = basketRows.flatMap<RuntimeElectiveOption>(basket => (
  2918	    (optionsByBasketId.get(basket.electiveBasketId) ?? []).map(option => ({
  2919	      stream: basket.stream,
  2920	      pceGroup: basket.pceGroup,
  2921	      code: option.code,
  2922	      title: option.title,
  2923	      semesterSlot: option.semesterSlot,
  2924	    }))
  2925	  ))
  2926	
  2927	  return {
  2928	    courses,
  2929	    electives,
  2930	  }
  2931	}
