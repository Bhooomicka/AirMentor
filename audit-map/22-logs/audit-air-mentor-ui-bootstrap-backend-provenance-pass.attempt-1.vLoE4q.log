    56	function weekdayFromDateIso(value: string) {
    57	  const parsed = new Date(value)
    58	  const weekday = parsed.getUTCDay()
    59	  return (['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'][weekday] ?? null) as string | null
    60	}
    61	
    62	function timetableBlocksCanOverlap(
    63	  left: { kind?: string; dateISO?: string; day: string },
    64	  right: { kind?: string; dateISO?: string; day: string },
    65	) {
    66	  if (left.kind === 'extra' && left.dateISO && right.kind === 'extra' && right.dateISO) {
    67	    return left.dateISO === right.dateISO
    68	  }
    69	  if (left.kind === 'extra' && left.dateISO && right.kind !== 'extra') {
    70	    return weekdayFromDateIso(left.dateISO) === right.day
    71	  }
    72	  if (right.kind === 'extra' && right.dateISO && left.kind !== 'extra') {
    73	    return weekdayFromDateIso(right.dateISO) === left.day
    74	  }
    75	  return left.day === right.day
    76	}
    77	
    78	function timetableRangesOverlap(
    79	  left: { startMinutes: number; endMinutes: number },
    80	  right: { startMinutes: number; endMinutes: number },
    81	) {
    82	  return left.startMinutes < right.endMinutes && right.startMinutes < left.endMinutes
    83	}
