   368	
   369	export function startProofRunWorker(input: {
   370	  db: AppDb
   371	  pool: Pick<Pool, 'query'>
   372	  clock?: () => string
   373	  pollMs?: number
   374	  heartbeatMs?: number
   375	  startDelayMs?: number
   376	}) {
   377	  const now = input.clock ?? (() => new Date().toISOString())
   378	  const pollMs = input.pollMs ?? WORKER_POLL_MS
   379	  const heartbeatMs = input.heartbeatMs ?? WORKER_HEARTBEAT_MS
   380	  const startDelayMs = input.startDelayMs ?? 2_000
   381	  let disposed = false
   382	  let timeout: NodeJS.Timeout | null = null
   383	  let heartbeat: NodeJS.Timeout | null = null
   384	  let running = false
   385	  let activeTick: Promise<void> | null = null
   386	
   387	  const schedule = (delayMs: number) => {
   388	    if (disposed) return
   389	    timeout = setTimeout(() => {
   390	      timeout = null
   391	      activeTick = tick().catch(error => {
   392	        console.error('Proof worker tick failed', error)
   393	      }).finally(() => {
   394	        if (activeTick) activeTick = null
   395	      })
   396	    }, delayMs)
   397	  }
   398	
   399	  const tick = async () => {
   400	    if (disposed || running) return
   401	    running = true
   402	    try {
   403	      const leaseToken = createId('proof_worker_lease')
   404	      const claimed = await claimNextQueuedProofRun(input.pool, now(), leaseToken)
   405	      if (!claimed) return
   406	      emitOperationalEvent('proof.run.claimed', {
   407	        simulationRunId: claimed.simulation_run_id,
   408	        batchId: claimed.batch_id,
   409	        leaseToken,
   410	        priorStatus: claimed.status,
   411	      })
   412	
   413	      heartbeat = setInterval(() => {
   414	        void heartbeatProofRunLease(input.pool, {
   415	          simulationRunId: claimed.simulation_run_id,
   416	          leaseToken,
   417	          now: now(),
   418	        }).catch(error => {
   419	          if (!disposed) console.error('Proof worker heartbeat failed', error)
   420	        })
   421	      }, heartbeatMs)
   422	
   423	      try {
   424	        await executeClaimedProofRun(input.db, claimed)
   425	        await finalizeProofRunLease(input.pool, {
   426	          simulationRunId: claimed.simulation_run_id,
   427	          leaseToken,
   428	          now: now(),
   429	        })
   430	        emitOperationalEvent('proof.run.executed', {
   431	          simulationRunId: claimed.simulation_run_id,
   432	          batchId: claimed.batch_id,
   433	          leaseToken,
   434	        })
   435	      } catch (error) {
   436	        await failProofRun(input.pool, {
   437	          simulationRunId: claimed.simulation_run_id,
   438	          leaseToken,
   439	          now: now(),
   440	          error,
   441	        })
   442	        emitOperationalEvent('proof.run.failed', {
   443	          simulationRunId: claimed.simulation_run_id,
   444	          batchId: claimed.batch_id,
   445	          leaseToken,
   446	          error: normalizeTelemetryError(error),
   447	        }, { level: 'error' })
   448	        console.error('Proof worker execution failed', error)
   449	      } finally {
   450	        if (heartbeat) {
   451	          clearInterval(heartbeat)
   452	          heartbeat = null
   453	        }
   454	      }
   455	    } finally {
   456	      running = false
   457	      if (!disposed) schedule(pollMs)
   458	    }
   459	  }
   460	

