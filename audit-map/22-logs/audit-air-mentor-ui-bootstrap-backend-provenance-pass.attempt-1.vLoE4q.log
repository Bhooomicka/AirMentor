    55	    const checkpoint = input.checkpointBySemesterStage.get(`${first.semesterNumber}::${String(firstProjection.stageKey ?? '')}`)
    56	      ?? input.orderedCheckpointRows.find(row => row.simulationStageCheckpointId === first.simulationStageCheckpointId)
    57	    if (!checkpoint) return
    58	
    59	    const pendingAction = [...new Set(rows.map(row => row.simulatedActionTaken).filter((value): value is string => !!value))][0] ?? null
