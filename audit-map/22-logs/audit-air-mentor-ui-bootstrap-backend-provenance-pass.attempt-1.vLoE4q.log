    62	function diffSeconds(laterIso: string, earlierIso: string | null | undefined) {
    63	  if (!earlierIso) return null
    64	  const later = Date.parse(laterIso)
    65	  const earlier = Date.parse(earlierIso)
    66	  if (!Number.isFinite(later) || !Number.isFinite(earlier)) return null
    67	  return Math.max(0, Math.round((later - earlier) / 1000))
    68	}
    69	
    70	function resolveLeaseState(run: ProofRunCore, nowIso: string): ProofRunWithOperationalDiagnostics['leaseState'] {
    71	  if (run.workerLeaseExpiresAt) {
    72	    const expiresAt = Date.parse(run.workerLeaseExpiresAt)
    73	    const now = Date.parse(nowIso)
    74	    if (Number.isFinite(expiresAt) && Number.isFinite(now)) {
    75	      return expiresAt > now ? 'leased' : 'expired'
    76	    }
    77	  }
    78	  if (run.status !== 'queued' && run.status !== 'running') return 'released'
    79	  return null
    80	}
    81	
    82	export function decorateProofRunsWithOperationalDiagnostics<T extends ProofRunCore>(
    83	  runs: T[],
    84	  nowIso: string,
    85	): Array<T & ProofRunWithOperationalDiagnostics> {
    86	  return runs.map(run => {
    87	    const retryOfSimulationRunId = typeof run.progress?.retryOf === 'string' ? run.progress.retryOf : null
    88	    const retryState = retryOfSimulationRunId
    89	      ? 'retry-of-previous-run'
    90	      : run.status === 'failed'
    91	        ? 'retryable'
    92	        : null
    93	    return {
    94	      ...run,
    95	      queueAgeSeconds: run.status === 'queued'
    96	        ? diffSeconds(nowIso, run.createdAt)
    97	        : run.status === 'running'
    98	          ? diffSeconds(nowIso, run.startedAt ?? run.createdAt)
    99	          : null,
   100	      leaseState: resolveLeaseState(run, nowIso),
   101	      leaseExpiresAt: run.workerLeaseExpiresAt,
   102	      retryState,
   103	      retryOfSimulationRunId,
   104	      failureState: run.status === 'failed' ? 'retryable' : 'none',
   105	    }
   106	  })
   107	}
   108	
   109	export function buildProofQueueDiagnostics(
   110	  runs: ProofRunWithOperationalDiagnostics[],
   111	): ProofQueueDiagnostics {
   112	  const queuedRuns = runs.filter(run => run.status === 'queued')
   113	  const oldestQueuedRunAgeSeconds = queuedRuns
   114	    .map(run => run.queueAgeSeconds)
   115	    .filter((value): value is number => typeof value === 'number')
   116	    .sort((left, right) => right - left)[0] ?? null
   117	
   118	  return {
   119	    queuedRunCount: queuedRuns.length,
   120	    runningRunCount: runs.filter(run => run.status === 'running').length,
   121	    failedRunCount: runs.filter(run => run.status === 'failed').length,
   122	    retryableRunCount: runs.filter(run => run.retryState === 'retryable').length,
   123	    retryInFlightCount: runs.filter(run => run.retryState === 'retry-of-previous-run').length,
   124	    oldestQueuedRunAgeSeconds,
   125	    expiredLeaseRunCount: runs.filter(run => run.leaseState === 'expired').length,
   126	  }
   127	}
   128	
   129	export function buildProofWorkerDiagnostics(
   130	  activeRun: ProofRunWithOperationalDiagnostics | null,
   131	): ProofWorkerDiagnostics | null {
   132	  if (!activeRun) return null
   133	  return {
   134	    queueAgeSeconds: activeRun.queueAgeSeconds,
   135	    leaseState: activeRun.leaseState,
   136	    leaseExpiresAt: activeRun.leaseExpiresAt,
   137	    retryState: activeRun.retryState,
   138	    retryOfSimulationRunId: activeRun.retryOfSimulationRunId,
   139	    failureState: activeRun.failureState,
   140	    progressPhase: typeof activeRun.progress?.phase === 'string' ? activeRun.progress.phase : null,
   141	    progressPercent: typeof activeRun.progress?.percent === 'number' ? activeRun.progress.percent : null,
   142	  }
   143	}
