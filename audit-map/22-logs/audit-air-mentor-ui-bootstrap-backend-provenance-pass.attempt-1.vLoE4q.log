   865	function summarizeQuestionPatterns(input: {
   866	  rows: Array<typeof studentQuestionResults.$inferSelect>
   867	  templatesById: Map<string, typeof simulationQuestionTemplates.$inferSelect>
   868	}) {
   869	  const weakTopicCounts = new Map<string, number>()
   870	  const weakCoCounts = new Map<string, number>()
   871	  let weakQuestionCount = 0
   872	  let carelessErrorCount = 0
   873	  let transferGapCount = 0
   874	
   875	  input.rows.forEach(row => {
   876	    const result = parseJson(row.resultJson, {} as Record<string, unknown>)
   877	    const template = input.templatesById.get(row.simulationQuestionTemplateId)
   878	    const score = Number(result.studentScoreOnQuestion ?? row.score)
   879	    const maxScore = Number(row.maxScore)
   880	    const errorType = String(result.errorTypeObserved ?? 'clean')
   881	    if (errorType === 'careless-error') carelessErrorCount += 1
   882	    if (errorType === 'transfer-gap') transferGapCount += 1
   883	    if (maxScore > 0 && (score / maxScore) < 0.4) {
   884	      weakQuestionCount += 1
   885	      const topics = parseJson(template?.topicTagsJson ?? '[]', [] as string[])
   886	      const cos = parseJson(template?.coTagsJson ?? '[]', [] as string[])
   887	      topics.forEach(topic => weakTopicCounts.set(topic, (weakTopicCounts.get(topic) ?? 0) + 1))
   888	      cos.forEach(coCode => weakCoCounts.set(coCode, (weakCoCounts.get(coCode) ?? 0) + 1))
   889	    }
   890	  })
   891	
   892	  const rankMap = (source: Map<string, number>) => [...source.entries()]
   893	    .sort((left, right) => right[1] - left[1] || left[0].localeCompare(right[0]))
   894	    .slice(0, 6)
   895	    .map(([label]) => label)
   896	
   897	  return {
   898	    weakQuestionCount,
   899	    carelessErrorCount,
   900	    transferGapCount,
   901	    commonWeakTopics: rankMap(weakTopicCounts),
   902	    commonWeakCourseOutcomes: rankMap(weakCoCounts),
   903	  }
