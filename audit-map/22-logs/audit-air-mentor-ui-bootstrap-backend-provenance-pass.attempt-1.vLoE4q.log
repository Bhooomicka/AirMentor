## air-mentor-api/src/lib/proof-active-run.ts
     1	type ActiveRunLike = {
     2	  updatedAt: string
     3	  createdAt: string
     4	  activeOperationalSemester: number | null
     5	  runLabel: string
     6	}
     7	
     8	export function pickMostRecentActiveRun<T extends ActiveRunLike>(runs: T[]): T | null {
     9	  return runs
    10	    .slice()
    11	    .sort((left, right) => (
    12	      right.updatedAt.localeCompare(left.updatedAt)
    13	      || right.createdAt.localeCompare(left.createdAt)
    14	      || ((right.activeOperationalSemester ?? 0) - (left.activeOperationalSemester ?? 0))
    15	      || left.runLabel.localeCompare(right.runLabel)
    16	    ))[0] ?? null
    17	}

