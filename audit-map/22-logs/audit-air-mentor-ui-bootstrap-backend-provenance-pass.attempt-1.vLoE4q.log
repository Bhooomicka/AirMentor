    89	function buildLiveAttendanceHistory(
    90	  input: {
    91	    attendancePct: number
    92	    presentClasses: number
    93	    totalClasses: number
    94	  },
    95	) {
    96	  const checkpoints = [
    97	    { checkpoint: 'wk4', checkpointLabel: 'Week 4', totalClasses: 8 },
    98	    { checkpoint: 'wk8', checkpointLabel: 'Week 8', totalClasses: 16 },
    99	    { checkpoint: 'wk12', checkpointLabel: 'Week 12', totalClasses: 24 },
   100	    { checkpoint: 'wk16', checkpointLabel: 'Week 16', totalClasses: 32 },
   101	  ]
   102	  const safeTotalClasses = Math.max(0, input.totalClasses)
   103	  const safePresentClasses = Math.max(0, input.presentClasses)
   104	  const effectivePct = safeTotalClasses > 0
   105	    ? Math.max(0, Math.min(100, Math.round((safePresentClasses / safeTotalClasses) * 100)))
   106	    : Math.max(0, Math.min(100, Math.round(input.attendancePct)))
   107	  return checkpoints.map(checkpoint => {
   108	    const scaledTotal = safeTotalClasses > 0 ? Math.min(checkpoint.totalClasses, safeTotalClasses) : checkpoint.totalClasses
   109	    const scaledPresent = Math.min(
   110	      scaledTotal,
   111	      safeTotalClasses > 0
   112	        ? Math.round((safePresentClasses / Math.max(1, safeTotalClasses)) * scaledTotal)
   113	        : Math.round((effectivePct / 100) * scaledTotal),
   114	    )
   115	    return {
   116	      checkpoint: checkpoint.checkpoint,
   117	      checkpointLabel: checkpoint.checkpointLabel,
   118	      presentClasses: scaledPresent,
   119	      totalClasses: scaledTotal,
   120	      attendancePct: scaledTotal > 0 ? Math.round((scaledPresent / scaledTotal) * 100) : effectivePct,
   121	    }
   122	  })
   123	}
