    49	    await db.delete(simulationStageQueueCases).where(inArray(simulationStageQueueCases.simulationStageCheckpointId, checkpointIds))
    50	    await db.delete(simulationStageOfferingProjections).where(inArray(simulationStageOfferingProjections.simulationStageCheckpointId, checkpointIds))
    51	    await db.delete(simulationStageStudentProjections).where(inArray(simulationStageStudentProjections.simulationStageCheckpointId, checkpointIds))
