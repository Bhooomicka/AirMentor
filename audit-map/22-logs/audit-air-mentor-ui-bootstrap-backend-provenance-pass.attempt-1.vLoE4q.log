   267	  const activeRiskArtifacts = await deps.loadActiveProofRiskArtifacts(db, run.batchId)
   268	  const runEvidenceRows = await db.select().from(riskEvidenceSnapshots).where(eq(riskEvidenceSnapshots.simulationRunId, input.simulationRunId))
