  3067	        offeringFacultyById.set(current.offeringId, faculty.facultyId)
  3068	        return
  3069	      }
  3070	      const courseRow = courseByTitle.get(course.title)
  3071	      if (!courseRow) return
  3072	      const offeringId = `mnc_s6_${course.internalCompilerId.toLowerCase().replace(/[^a-z0-9]+/g, '_')}_${sectionCode.toLowerCase()}`
  3073	      newOfferingRows.push({
