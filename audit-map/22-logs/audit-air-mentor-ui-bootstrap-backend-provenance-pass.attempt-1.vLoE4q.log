   241	    await db.delete(reassessmentEvents).where(inArray(reassessmentEvents.reassessmentEventId, reassessmentIds))
   242	  }
   243	  if (riskIds.length > 0) {
   244	    await db.delete(riskOverrides).where(inArray(riskOverrides.riskAssessmentId, riskIds))
   245	    await db.delete(riskAssessments).where(inArray(riskAssessments.riskAssessmentId, riskIds))
