    40	  if (input.semesterNumber < run.semesterStart || input.semesterNumber > run.semesterEnd) {
    41	    throw new Error(`Semester ${input.semesterNumber} is outside the proof run range ${run.semesterStart}-${run.semesterEnd}`)
    42	  }
    43	
    44	  const checkpointRows = await db.select().from(simulationStageCheckpoints).where(
    45	    eq(simulationStageCheckpoints.simulationRunId, run.simulationRunId),
    46	  ).orderBy(
