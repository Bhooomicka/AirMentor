   236	    studentCount: activeEnrollments.length,
   237	    facultyCount: new Set(ownershipRows.filter(row => relevantOfferingIds.has(row.offeringId ?? '')).map(row => row.facultyId)).size,
   238	    semesterStart: activeTerm.semesterNumber,
   239	    semesterEnd: activeTerm.semesterNumber,
   240	    activeOperationalSemester: activeTerm.semesterNumber,
