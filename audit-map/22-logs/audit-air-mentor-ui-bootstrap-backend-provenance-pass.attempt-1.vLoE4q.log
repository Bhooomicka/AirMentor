   311	      stageCloseEvidenceByStudentOffering.set(`${row.studentId}::${row.offeringId ?? row.courseCode}`, {
   312	        featurePayload,
   313	        labelPayload,
   314	        sourceRefs,
   315	      })
   316	    })
   317	
   318	  const liveStageSourceKey = (studentId: string, offeringId: string, courseCode: string) => `${studentId}::${currentSemesterNumber}::${offeringId}::${courseCode}`
   319	  const liveCaseKey = (studentId: string) => `${studentId}::${currentSemesterNumber}`
   320	  const liveQueueCaseId = (studentId: string, stageKey: ProofQueueGovernanceStageKey) => deps.buildDeterministicId('runtime_queue_case', [input.simulationRunId, studentId, currentSemesterNumber, stageKey])
   321	  const courseLeaderFacultyIdByOfferingId = new Map<string, string>()
   322	  ownershipRows
   323	    .filter(row => row.offeringId != null)
   324	    .slice()
   325	    .sort((left, right) => left.facultyId.localeCompare(right.facultyId))
   326	    .forEach(row => {
   327	      if (!row.offeringId || courseLeaderFacultyIdByOfferingId.has(row.offeringId)) return
   328	      courseLeaderFacultyIdByOfferingId.set(row.offeringId, row.facultyId)
   329	    })
   330	  const mentorFacultyIdByStudentId = new Map<string, string>()
