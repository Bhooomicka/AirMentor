   145	export function buildCheckpointReadinessDiagnostics(
   146	  checkpoints: ProofCheckpointSummaryCore[],
   147	): ProofCheckpointReadinessDiagnostics {
   148	  const blockedCheckpoints = checkpoints.filter(checkpoint => (
   149	    checkpoint.playbackAccessible === false
   150	    || checkpoint.stageAdvanceBlocked === true
   151	  ))
   152	  const readyCheckpoints = checkpoints.filter(checkpoint => (
   153	    checkpoint.playbackAccessible !== false
   154	    && checkpoint.stageAdvanceBlocked !== true
   155	  ))
   156	  return {
   157	    totalCheckpointCount: checkpoints.length,
   158	    readyCheckpointCount: readyCheckpoints.length,
   159	    blockedCheckpointCount: blockedCheckpoints.length,
   160	    playbackBlockedCheckpointCount: checkpoints.filter(checkpoint => checkpoint.playbackAccessible === false).length,
   161	    totalBlockingQueueItemCount: checkpoints.reduce((sum, checkpoint) => (
