   132	export function buildFacultyTimetableTemplates(loadsByFacultyId: Map<string, FacultyLoadTemplateEntry[]>) {
   133	  const weekdays = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri'] as const
   134	  const slots = [
   135	    { id: 'slot_1', label: '08:30-09:30', startTime: '08:30', endTime: '09:30' },
   136	    { id: 'slot_2', label: '09:30-10:30', startTime: '09:30', endTime: '10:30' },
   137	    { id: 'slot_3', label: '10:45-11:45', startTime: '10:45', endTime: '11:45' },
   138	    { id: 'slot_4', label: '11:45-12:45', startTime: '11:45', endTime: '12:45' },
   139	    { id: 'slot_5', label: '13:30-14:30', startTime: '13:30', endTime: '14:30' },
   140	    { id: 'slot_6', label: '14:30-15:30', startTime: '14:30', endTime: '15:30' },
   141	  ] as const
   142	  const result: Record<string, Record<string, unknown>> = {}
   143	
   144	  for (const [facultyId, entries] of loadsByFacultyId.entries()) {
   145	    const classBlocks: Array<Record<string, unknown>> = []
   146	    const orderedEntries = [...entries].sort((left, right) => (
   147	      left.semesterNumber - right.semesterNumber
   148	      || left.courseCode.localeCompare(right.courseCode)
   149	      || left.sectionCode.localeCompare(right.sectionCode)
   150	      || left.offeringId.localeCompare(right.offeringId)
   151	    ))
   152	    const occupiedPositions = new Set<string>()
   153	    const dayLoad = new Map(weekdays.map(day => [day, 0]))
   154	    const dayOffset = Math.floor(stableUnit(`timetable-day-${facultyId}`) * weekdays.length) % weekdays.length
   155	    const slotOffset = Math.floor(stableUnit(`timetable-slot-${facultyId}`) * slots.length) % slots.length
   156	    const orderedDays = weekdays.slice(dayOffset).concat(weekdays.slice(0, dayOffset))
   157	
   158	    const takeNextFreePosition = (usedDaysForEntry: Set<string>) => {
   159	      const preferredDays = [...orderedDays].sort((left, right) => {
   160	        const leftPenalty = usedDaysForEntry.has(left) ? 1 : 0
   161	        const rightPenalty = usedDaysForEntry.has(right) ? 1 : 0
   162	        if (leftPenalty !== rightPenalty) return leftPenalty - rightPenalty
   163	        return (dayLoad.get(left) ?? 0) - (dayLoad.get(right) ?? 0)
   164	      })
   165	      for (const day of preferredDays) {
   166	        for (let offset = 0; offset < slots.length; offset += 1) {
   167	          const slot = slots[(slotOffset + offset) % slots.length]!
   168	          const key = `${day}:${slot.id}`
   169	          if (occupiedPositions.has(key)) continue
   170	          occupiedPositions.add(key)
   171	          dayLoad.set(day, (dayLoad.get(day) ?? 0) + 1)
   172	          return { day, slot }
   173	        }
   174	      }
   175	      throw new Error(`Timetable builder exhausted weekly slot capacity for ${facultyId}`)
   176	    }
   177	
   178	    orderedEntries.forEach(entry => {
   179	      const repeatCount = Math.max(1, Math.min(3, entry.weeklyHours))
   180	      const usedDaysForEntry = new Set<string>()
   181	      for (let blockIndex = 0; blockIndex < repeatCount; blockIndex += 1) {
   182	        const position = takeNextFreePosition(usedDaysForEntry)
   183	        const { day, slot } = position
   184	        usedDaysForEntry.add(day)
   185	        classBlocks.push({
   186	          id: `${facultyId}_${entry.offeringId}_${blockIndex + 1}`,
   187	          facultyId,
   188	          offeringId: entry.offeringId,
   189	          courseCode: entry.courseCode,
   190	          courseName: entry.courseName,
   191	          section: entry.sectionCode,
   192	          year: `${Math.ceil(entry.semesterNumber / 2)} Year`,
   193	          day,
   194	          kind: 'regular',
   195	          startMinutes: Number(slot.startTime.slice(0, 2)) * 60 + Number(slot.startTime.slice(3, 5)),
   196	          endMinutes: Number(slot.endTime.slice(0, 2)) * 60 + Number(slot.endTime.slice(3, 5)),
   197	          slotId: slot.id,
   198	          slotSpan: 1,
   199	        })
   200	      }
   201	    })
   202	
   203	    result[facultyId] = {
   204	      facultyId,
   205	      slots,
   206	      dayStartMinutes: 8 * 60 + 30,
   207	      dayEndMinutes: 15 * 60 + 30,
   208	      classBlocks,
   209	      updatedAt: Date.now(),
   210	    }
   211	  }
   212	
   213	  return result
   214	}

