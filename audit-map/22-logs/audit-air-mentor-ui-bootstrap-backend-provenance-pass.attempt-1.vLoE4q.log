    32	export async function activateProofOperationalSemester(
    33	  db: AppDb,
    34	  input: ActivateProofOperationalSemesterInput,
    35	  deps: ProofControlPlaneActivationServiceDeps,
    36	) {
    37	  const [run] = await db.select().from(simulationRuns).where(eq(simulationRuns.simulationRunId, input.simulationRunId))
    38	  if (!run) throw new Error('Simulation run not found')
