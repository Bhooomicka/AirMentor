   213	export async function retryQueuedProofSimulationRun(db: AppDb, input: {
   214	  simulationRunId: string
   215	  now: string
   216	}) {
   217	  const [run] = await db.select().from(simulationRuns).where(eq(simulationRuns.simulationRunId, input.simulationRunId))
   218	  if (!run) throw new Error('Simulation run not found')
   219	  await db.update(simulationRuns).set({
   220	    status: 'queued',
   221	    activeFlag: 0,
   222	    progressJson: JSON.stringify({
   223	      phase: 'queued',
   224	      percent: 0,
   225	      requestedActivate: Boolean(parseJson(run.progressJson, {} as Record<string, unknown>).requestedActivate ?? true),
   226	      mode: run.sourceType,
   227	      retryOf: run.simulationRunId,
   228	    }),
   229	    startedAt: null,
   230	    completedAt: null,
   231	    failureCode: null,
   232	    failureMessage: null,
   233	    workerLeaseToken: null,
   234	    workerLeaseExpiresAt: null,
   235	    updatedAt: input.now,
   236	  }).where(eq(simulationRuns.simulationRunId, input.simulationRunId))
   237	  emitOperationalEvent('proof.run.requeued', {
   238	    simulationRunId: run.simulationRunId,
   239	    batchId: run.batchId,
   240	    curriculumImportVersionId: run.curriculumImportVersionId,
   241	  })
   242	  return {
   243	    simulationRunId: run.simulationRunId,
   244	    status: 'queued',
   245	    activeFlag: false,
   246	    createdAt: run.createdAt,
   247	    startedAt: null,
   248	    completedAt: null,
   249	    failureCode: null,
   250	    failureMessage: null,
   251	    progress: {
