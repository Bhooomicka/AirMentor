  3058	  const newOwnershipRows: Array<typeof facultyOfferingOwnerships.$inferInsert> = []
  3059	  const offeringFacultyById = new Map<string, string>()
  3060	
  3061	  ;(['A', 'B'] as const).forEach((sectionCode, sectionOffset) => {
  3062	    sem6Courses.forEach((course, courseIndex) => {
  3063	      const key = `${course.title}::${sectionCode}`
  3064	      const current = currentByKey.get(key)
  3065	      const faculty = courseLeaderFaculty[(courseIndex + (sectionOffset * 3)) % courseLeaderFaculty.length]
