   178	export async function restoreProofSimulationSnapshot(db: AppDb, input: {
   179	  simulationRunId: string
   180	  simulationResetSnapshotId?: string
   181	  policy: ResolvedPolicy
   182	  actorFacultyId?: string | null
   183	  now: string
   184	}, deps: ProofControlPlaneRuntimeServiceDeps) {
   185	  const [run] = await db.select().from(simulationRuns).where(eq(simulationRuns.simulationRunId, input.simulationRunId))
   186	  if (!run) throw new Error('Simulation run not found')
   187	  const snapshotRows = await db.select().from(simulationResetSnapshots).where(eq(simulationResetSnapshots.simulationRunId, run.simulationRunId)).orderBy(desc(simulationResetSnapshots.createdAt))
   188	  const snapshot = input.simulationResetSnapshotId
   189	    ? snapshotRows.find(row => row.simulationResetSnapshotId === input.simulationResetSnapshotId)
   190	    : snapshotRows[0]
   191	  if (!snapshot) throw new Error('Simulation snapshot not found')
   192	  const payload = parseJson(snapshot.snapshotJson, {} as Record<string, unknown>)
   193	  return deps.startProofSimulationRun(db, {
   194	    batchId: run.batchId,
   195	    curriculumImportVersionId: String(payload.curriculumImportVersionId ?? run.curriculumImportVersionId ?? ''),
   196	    policy: input.policy,
   197	    curriculumFeatureProfileId: run.curriculumFeatureProfileId ?? null,
   198	    curriculumFeatureProfileFingerprint: run.curriculumFeatureProfileFingerprint ?? null,
   199	    actorFacultyId: input.actorFacultyId,
   200	    now: input.now,
   201	    seed: Number(payload.seed ?? run.seed),
   202	    runLabel: `${run.runLabel} restored`,
   203	    parentSimulationRunId: run.simulationRunId,
   204	    activate: true,
   205	  })
   206	}
