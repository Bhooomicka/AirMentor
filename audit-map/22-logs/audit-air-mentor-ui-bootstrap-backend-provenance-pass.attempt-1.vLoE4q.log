  2066	function deriveScenarioRiskHeads(input: {
  2067	  currentRiskProbScaled: number | null
  2068	  currentCgpa: number
  2069	  backlogCount: number
  2070	  weakCoCount: number
  2071	  transferGapCount: number
  2072	  hasElectiveFit: boolean
  2073	  currentSemesterSummary?: StudentAgentCardPayload['overview']['semesterSummaries'][number] | null
  2074	  previousSemesterSummary?: StudentAgentCardPayload['overview']['semesterSummaries'][number] | null
  2075	}, deps: ProofControlPlaneTailServiceDeps) {
  2076	  const overallRisk = deps.clamp((input.currentRiskProbScaled ?? 0) / 100, 0.05, 0.95)
  2077	  const backlogPressure = deps.clamp(input.backlogCount / 4, 0, 1)
  2078	  const lowCgpaPressure = deps.clamp((7.5 - input.currentCgpa) / 4, 0, 1)
  2079	  const sgpaTrendPressure = input.currentSemesterSummary && input.previousSemesterSummary
  2080	    ? deps.clamp((input.previousSemesterSummary.sgpa - input.currentSemesterSummary.sgpa + 1.5) / 4, 0, 1)
  2081	    : deps.clamp((6.5 - input.currentCgpa) / 4, 0, 1)
  2082	  const coPressure = deps.clamp(input.weakCoCount / 4, 0, 1)
  2083	  const transferGapPressure = deps.clamp(input.transferGapCount / 5, 0, 1)
  2084	
  2085	  return {
  2086	    semesterSgpaDropRiskProbScaled: Math.round(deps.clamp(
  2087	      (overallRisk * 0.55) + (backlogPressure * 0.2) + (sgpaTrendPressure * 0.25),
  2088	      0.05,
  2089	      0.95,
  2090	    ) * 100),
  2091	    cumulativeCgpaDropRiskProbScaled: Math.round(deps.clamp(
  2092	      (overallRisk * 0.45) + (backlogPressure * 0.25) + (lowCgpaPressure * 0.3),
  2093	      0.05,
  2094	      0.95,
  2095	    ) * 100),
  2096	    electiveMismatchRiskProbScaled: input.hasElectiveFit
  2097	      ? Math.round(deps.clamp(
  2098	        (overallRisk * 0.45) + (coPressure * 0.25) + (transferGapPressure * 0.15) + (backlogPressure * 0.15),
  2099	        0.05,
  2100	        0.95,
  2101	      ) * 100)
  2102	      : null,
  2103	    note: 'These scenario heads are derived from the trained course-risk heads plus observed semester trend, backlog pressure, weak course outcomes, and elective-fit visibility. They are advisory and simulation-calibrated.',
  2104	  }
  2105	}
