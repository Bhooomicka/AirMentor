    45	    eq(simulationStageCheckpoints.simulationRunId, run.simulationRunId),
    46	  ).orderBy(
    47	    asc(simulationStageCheckpoints.semesterNumber),
    48	    asc(simulationStageCheckpoints.stageOrder),
    49	  )
