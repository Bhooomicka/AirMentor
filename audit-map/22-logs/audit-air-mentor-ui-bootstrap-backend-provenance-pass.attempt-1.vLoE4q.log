   134	function latestRowByKey<T extends { updatedAt: string; createdAt: string }>(rows: T[], keyOf: (row: T) => string) {
   135	  const latest = new Map<string, T>()
   136	  rows.forEach(row => {
   137	    const key = keyOf(row)
   138	    const current = latest.get(key)
   139	    if (!current || row.updatedAt > current.updatedAt || (row.updatedAt === current.updatedAt && row.createdAt > current.createdAt)) {
   140	      latest.set(key, row)
   141	    }
   142	  })
   143	  return latest
   144	}
