   127	  input.teacherAllocationRows.forEach(row => {
   128	    const key = `${row.facultyId}::${row.semesterNumber}`
   129	    perFacultySemester.set(key, [...(perFacultySemester.get(key) ?? []), row])
   130	  })
   131	  for (const faculty of deps.PROOF_FACULTY) {
   132	    for (let semesterNumber = 1; semesterNumber <= 6; semesterNumber += 1) {
   133	      const allocations = perFacultySemester.get(`${faculty.facultyId}::${semesterNumber}`) ?? []
   134	      teacherLoadRows.push({
   135	        teacherLoadProfileId: deps.createId('teacher_load'),
   136	        simulationRunId: input.simulationRunId,
   137	        facultyId: faculty.facultyId,
   138	        semesterNumber,
   139	        sectionLoadCount: allocations.length,
   140	        weeklyContactHours: allocations.reduce((sum, row) => sum + row.plannedContactHours, 0),
   141	        assignedCredits: allocations.reduce((sum, row) => sum + (row.plannedContactHours > 0 ? 1 : 0), 0),
   142	        permissionsJson: JSON.stringify(faculty.permissions),
   143	        createdAt: input.now,
   144	        updatedAt: input.now,
   145	      })
   146	    }
   147	  }
   148	
   149	  if (input.teacherAllocationRows.length > 0) await deps.insertRowsInChunks(db, teacherAllocations, input.teacherAllocationRows)
