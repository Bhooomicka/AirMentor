   184	  ])
   185	
   186	  const activeTerm = termRows
   187	    .filter(row => row.status === 'active')
   188	    .slice()
   189	    .sort((left, right) => right.semesterNumber - left.semesterNumber || right.updatedAt.localeCompare(left.updatedAt))[0]
   190	    ?? termRows
   191	      .slice()
   192	      .sort((left, right) => right.semesterNumber - left.semesterNumber || right.updatedAt.localeCompare(left.updatedAt))[0]
