  3005	function electiveRecommendationForStudent(input: {
  3006	  courseScores: Map<string, number>
  3007	  electives: RuntimeElectiveOption[]
  3008	}) {
  3009	  const streamRules = [
  3010	    { stream: 'Coding and Cryptography', titles: ['Discrete Mathematics', 'Digital Logic Design', 'Theory of Computation', 'Data Structures and Algorithms'], rationale: ['strong symbolic reasoning', 'good performance on formal and logic-heavy courses'] },
  3011	    { stream: 'Mathematical Models', titles: ['Engineering Mathematics-1', 'Engineering Mathematics-2', 'Linear Algebra', 'Probability and Statistics'], rationale: ['stable mathematical foundation', 'consistent performance on proof-oriented mathematics'] },
  3012	    { stream: 'Artificial Intelligence and Data Sciences', titles: ['Programming in C', 'Python Programming', 'Machine Learning', 'Probability and Statistics'], rationale: ['applied modelling strength', 'solid algorithmic and data reasoning profile'] },
  3013	    { stream: 'Software Development', titles: ['Object Oriented Programming', 'Database Management Systems', 'Operating Systems', 'Software Engineering'], rationale: ['strong systems and software stack performance', 'good consistency in implementation-heavy courses'] },
  3014	    { stream: 'Applied Mathematics', titles: ['Engineering Mathematics-1', 'Engineering Mathematics-2', 'Linear Algebra', 'Numerical Methods'], rationale: ['high readiness for quantitative electives', 'strong performance on analytical methods'] },
  3015	    { stream: 'Data Science and Analytics', titles: ['Python Programming', 'Probability and Statistics', 'Machine Learning', 'Scientific Computing Lab'], rationale: ['good preparation for data-centric electives', 'observable strength in modelling and computation'] },
  3016	  ]
  3017	  const sem6Options = input.electives.filter((option: RuntimeElectiveOption) => option.semesterSlot.toLowerCase() === 'sem 6')
  3018	  const scores = streamRules.map(rule => {
  3019	    const values = rule.titles.map(title => input.courseScores.get(title)).filter((value): value is number => typeof value === 'number')
  3020	    const score = values.length > 0 ? values.reduce((sum, value) => sum + value, 0) / values.length : 40
  3021	    const option = sem6Options.find((candidate: RuntimeElectiveOption) => candidate.stream === rule.stream)
  3022	    return {
  3023	      stream: rule.stream,
  3024	      option: option ?? sem6Options[0],
  3025	      score: roundToTwo(score),
  3026	      rationale: rule.rationale,
  3027	    }
  3028	  }).filter(item => item.option).sort((left, right) => right.score - left.score)
  3029	
  3030	  const best = scores[0]
  3031	  return {
  3032	    recommended: best.option,
  3033	    rationale: best.rationale,
  3034	    alternatives: scores.slice(1, 4).map(item => ({
  3035	      code: item.option.code,
  3036	      title: item.option.title,
  3037	      stream: item.option.stream,
  3038	      score: item.score,
  3039	    })),
  3040	  }
  3041	}
