    62	      highRiskCount: rows.filter(row => row.riskBand === 'High').length,
    63	      mediumRiskCount: rows.filter(row => row.riskBand === 'Medium').length,
    64	      openQueueCount: input.queueProjectionRows.filter(row =>
    65	        row.simulationStageCheckpointId === first.simulationStageCheckpointId
