   131	export async function enqueueProofSimulationRun(db: AppDb, input: {
   132	  batchId: string
   133	  curriculumImportVersionId: string
   134	  policy: ResolvedPolicy
   135	  curriculumFeatureProfileId?: string | null
   136	  curriculumFeatureProfileFingerprint?: string | null
   137	  now: string
   138	  seed?: number
   139	  runLabel?: string
   140	  parentSimulationRunId?: string | null
   141	  activate?: boolean
   142	}) {
   143	  const queueMetadata = await buildQueueMetadata(db, input.batchId)
   144	  const runSeed = input.seed ?? Math.floor(Date.now() % 100000)
   145	  const simulationRunId = createId('simulation_run')
   146	  const activateRequested = input.activate ?? true
   147	  const modeLabel = queueMetadata.sourceType === 'simulation' ? 'MSRUAS proof rerun' : 'Live batch proof run'
   148	  await db.insert(simulationRuns).values({
   149	    simulationRunId,
   150	    batchId: input.batchId,
   151	    curriculumImportVersionId: input.curriculumImportVersionId,
   152	    curriculumFeatureProfileId: input.curriculumFeatureProfileId ?? null,
   153	    curriculumFeatureProfileFingerprint: input.curriculumFeatureProfileFingerprint ?? null,
   154	    parentSimulationRunId: input.parentSimulationRunId ?? null,
   155	    runLabel: input.runLabel ?? `${modeLabel} ${runSeed}`,
   156	    status: 'queued',
   157	    activeFlag: 0,
   158	    seed: runSeed,
   159	    sectionCount: queueMetadata.sectionCount,
   160	    studentCount: queueMetadata.studentCount,
   161	    facultyCount: queueMetadata.facultyCount,
   162	    semesterStart: queueMetadata.semesterStart,
   163	    semesterEnd: queueMetadata.semesterEnd,
   164	    activeOperationalSemester: queueMetadata.semesterEnd,
   165	    sourceType: queueMetadata.sourceType,
   166	    policySnapshotJson: JSON.stringify(input.policy),
   167	    engineVersionsJson: JSON.stringify({
   168	      queueMode: 'background-worker',
   169	    }),
   170	    metricsJson: JSON.stringify(queueMetadata.metrics),
   171	    progressJson: JSON.stringify({
   172	      phase: 'queued',
   173	      percent: 0,
   174	      requestedActivate: activateRequested,
   175	      mode: queueMetadata.sourceType,
   176	    }),
   177	    startedAt: null,
   178	    completedAt: null,
   179	    failureCode: null,
   180	    failureMessage: null,
   181	    workerLeaseToken: null,
   182	    workerLeaseExpiresAt: null,
   183	    createdAt: input.now,
   184	    updatedAt: input.now,
   185	  })
   186	  emitOperationalEvent('proof.run.queued', {
   187	    simulationRunId,
   188	    batchId: input.batchId,
   189	    curriculumImportVersionId: input.curriculumImportVersionId,
   190	    curriculumFeatureProfileId: input.curriculumFeatureProfileId ?? null,
   191	    curriculumFeatureProfileFingerprint: input.curriculumFeatureProfileFingerprint ?? null,
   192	    sourceType: queueMetadata.sourceType,
   193	    requestedActivate: activateRequested,
   194	  })
   195	  return {
   196	    simulationRunId,
   197	    status: 'queued',
   198	    activeFlag: false,
   199	    createdAt: input.now,
   200	    startedAt: null,
   201	    completedAt: null,
   202	    failureCode: null,
   203	    failureMessage: null,
   204	    progress: {
   205	      phase: 'queued',
   206	      percent: 0,
   207	      requestedActivate: activateRequested,
   208	      mode: queueMetadata.sourceType,
   209	    } as Record<string, unknown>,
   210	  }
   211	}
