  2860	async function insertRowsInChunks<T>(db: AppDb, table: unknown, rows: T[], chunkSize = 400) {
  2861	  for (let index = 0; index < rows.length; index += chunkSize) {
  2862	    const batch = rows.slice(index, index + chunkSize)
  2863	    if (batch.length === 0) continue
  2864	    await db.insert(table as never).values(batch as never)
  2865	  }
  2866	}
