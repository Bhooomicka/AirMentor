   109	export function buildProofQueueDiagnostics(
   110	  runs: ProofRunWithOperationalDiagnostics[],
   111	): ProofQueueDiagnostics {
   112	  const queuedRuns = runs.filter(run => run.status === 'queued')
   113	  const oldestQueuedRunAgeSeconds = queuedRuns
   114	    .map(run => run.queueAgeSeconds)
   115	    .filter((value): value is number => typeof value === 'number')
   116	    .sort((left, right) => right - left)[0] ?? null
   117	
   118	  return {
   119	    queuedRunCount: queuedRuns.length,
   120	    runningRunCount: runs.filter(run => run.status === 'running').length,
   121	    failedRunCount: runs.filter(run => run.status === 'failed').length,
   122	    retryableRunCount: runs.filter(run => run.retryState === 'retryable').length,
   123	    retryInFlightCount: runs.filter(run => run.retryState === 'retry-of-previous-run').length,
   124	    oldestQueuedRunAgeSeconds,
