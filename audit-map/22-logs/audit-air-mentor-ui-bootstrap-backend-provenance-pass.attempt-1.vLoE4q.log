    18	) {
    19	  const [existingCards, existingSessions, existingCheckpoints, existingStageEvidenceRows] = await Promise.all([
    20	    db.select().from(studentAgentCards).where(eq(studentAgentCards.simulationRunId, simulationRunId)),
    21	    db.select().from(studentAgentSessions).where(eq(studentAgentSessions.simulationRunId, simulationRunId)),
    22	    db.select().from(simulationStageCheckpoints).where(eq(simulationStageCheckpoints.simulationRunId, simulationRunId)),
    23	    db.select().from(riskEvidenceSnapshots).where(eq(riskEvidenceSnapshots.simulationRunId, simulationRunId)),
    24	  ])
    25	
    26	  const stageCardIds = existingCards
    27	    .filter(row => !!row.simulationStageCheckpointId)
    28	    .map(row => row.studentAgentCardId)
    29	  const stageSessionIds = existingSessions
    30	    .filter(row => !!row.simulationStageCheckpointId)
    31	    .map(row => row.studentAgentSessionId)
    32	  const checkpointIds = existingCheckpoints.map(row => row.simulationStageCheckpointId)
    33	  const stageEvidenceIds = existingStageEvidenceRows
    34	    .filter(row => !!row.simulationStageCheckpointId)
    35	    .map(row => row.riskEvidenceSnapshotId)
    36	
    37	  if (stageSessionIds.length > 0) {
    38	    await db.delete(studentAgentMessages).where(inArray(studentAgentMessages.studentAgentSessionId, stageSessionIds))
    39	    await db.delete(studentAgentSessions).where(inArray(studentAgentSessions.studentAgentSessionId, stageSessionIds))
    40	  }
    41	  if (stageCardIds.length > 0) {
    42	    await db.delete(studentAgentCards).where(inArray(studentAgentCards.studentAgentCardId, stageCardIds))
    43	  }
    44	  if (stageEvidenceIds.length > 0) {
    45	    await db.delete(riskEvidenceSnapshots).where(inArray(riskEvidenceSnapshots.riskEvidenceSnapshotId, stageEvidenceIds))
    46	  }
    47	  if (checkpointIds.length > 0) {
