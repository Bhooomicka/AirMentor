   202	  const studentById = new Map(studentRows.filter(row => relevantStudentIds.has(row.studentId)).map(row => [row.studentId, row]))
   203	  const courseById = new Map(courseRows.map(row => [row.courseId, row]))
   204	  const curriculumByCourseId = new Map(curriculumRows.map(row => [row.courseId ?? `code:${row.courseCode}`, row]))
   205	  const profileByStudentId = new Map(profileRows.map(row => [row.studentId, row]))
   206	  const latestAttendanceByStudentOffering = latestRowByKey(
   207	    attendanceRows.filter(row => relevantOfferingIds.has(row.offeringId)),
