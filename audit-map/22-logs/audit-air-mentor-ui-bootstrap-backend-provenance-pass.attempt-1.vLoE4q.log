    70	async function resolveProofCheckpointForRun(
    71	  db: AppDb,
    72	  simulationRunId: string,
    73	  simulationStageCheckpointId: string,
    74	) {
    75	  const [checkpoint] = await db.select().from(simulationStageCheckpoints).where(
    76	    eq(simulationStageCheckpoints.simulationStageCheckpointId, simulationStageCheckpointId),
    77	  )
    78	  if (!checkpoint) throw notFound('Simulation stage checkpoint not found')
    79	  if (checkpoint.simulationRunId !== simulationRunId) {
    80	    throw notFound('Simulation stage checkpoint not found for the selected proof run')
    81	  }
    82	  return checkpoint
    83	}
