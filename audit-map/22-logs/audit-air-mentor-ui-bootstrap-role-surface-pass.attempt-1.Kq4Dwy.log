      actorRole: auth.activeRoleGrant.roleCode,
      actorFacultyId: auth.facultyId,
      affectedEntityRefs: body.targetEntityRefs,
    })
    await emitAuditEvent(context, {
      entityType: 'AdminRequest',
      entityId: adminRequestId,
      action: 'created',

