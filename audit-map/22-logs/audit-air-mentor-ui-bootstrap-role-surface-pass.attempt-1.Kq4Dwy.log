export function CalendarTimetablePage({
  onBack,
  currentTeacher,
  activeRole,
  allowedRoles,
  facultyOfferings,
  mergedTasks,
  meetings,
  resolvedTaskIds,
  timetable,
  adminMarkers,
  taskPlacements,
  onScheduleTask,
