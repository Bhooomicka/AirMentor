              </div>
            </div>
            <HScrollArea>
              <table style={{ width: '100%', borderCollapse: 'collapse' }}>
                <thead><tr>{['Code', 'Subject', 'Credits', role === 'Mentor' ? 'Grade' : 'Score', 'Grade Point', 'Result'].map(header => <TH key={header}>{header}</TH>)}</tr></thead>
