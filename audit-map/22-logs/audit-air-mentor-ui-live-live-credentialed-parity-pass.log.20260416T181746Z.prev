  const health = await pollHealth(apiBaseUrl)
  const report = {
    mode: 'health',
    generatedAt: new Date().toISOString(),
    apiBaseUrl,
    status: health.ok ? 'passed' : 'failed',
    health,
  }
  await writeJsonReport('railway-live-healthcheck.json', report)
