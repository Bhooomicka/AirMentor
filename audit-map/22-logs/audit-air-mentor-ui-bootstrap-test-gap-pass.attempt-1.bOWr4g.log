}

function buildCookieHeader(setCookieValues) {
  const pairs = []
  for (const item of setCookieValues) {
    const [cookiePair] = item.split(';')
    if (!cookiePair) continue
    pairs.push(cookiePair)
  }
  return pairs.join('; ')
}

