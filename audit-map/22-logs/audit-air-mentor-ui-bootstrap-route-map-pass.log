      }, offeringForScheme),
    }))
    setPage('upload')
  }, [allOfferings, defaultOffering, hasEntryStartedForOffering, role])

  const handleApproveUnlock = useCallback((taskId: string) => {
    setAllTasksList(prev => prev.map(task => task.id === taskId ? ({
