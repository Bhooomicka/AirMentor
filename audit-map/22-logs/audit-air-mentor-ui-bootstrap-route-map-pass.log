                  <PanelLabel label={card.overview.observedLabel} />
                  <div style={{ ...sora, fontSize: 16, fontWeight: 700, color: T.text }}>Current observed evidence</div>
                  <div style={{ ...mono, fontSize: 11, color: T.muted, lineHeight: 1.8 }}>
                    Attendance {Math.round(card.overview.currentEvidence.attendancePct)}% ┬Ę TT1 {Math.round(card.overview.currentEvidence.tt1Pct)}% ┬Ę TT2 {Math.round(card.overview.currentEvidence.tt2Pct)}% ┬Ę quiz {Math.round(card.overview.currentEvidence.quizPct)}% ┬Ę assignment {Math.round(card.overview.currentEvidence.assignmentPct)}% ┬Ę SEE {Math.round(card.overview.currentEvidence.seePct)}%.
                  </div>
                  {card.overview.currentEvidence.coEvidenceMode ? (
