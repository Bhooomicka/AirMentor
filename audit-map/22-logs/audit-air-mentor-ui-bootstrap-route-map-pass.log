                        {item.recoveryConfirmed != null ? <Chip color={item.recoveryConfirmed ? T.success : T.warning}>Recovery {item.recoveryConfirmed ? 'Confirmed' : 'Watch'}</Chip> : null}
                      </div>
                    </Card>
                  )) : <Chip color={T.dim}>No intervention history</Chip>}
                </Card>
              </div>
