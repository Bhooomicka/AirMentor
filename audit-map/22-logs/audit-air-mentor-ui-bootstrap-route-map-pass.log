                : tab === 'co'
                  ? <COTab cos={cos} rows={coAttainmentRows ?? []} />
                  : <GradeBookTab offering={offering} students={students} scheme={scheme} onOpenStudent={onOpenStudent} onOpenEntryHub={() => onOpenEntryHub('finals')} onOpenSchemeSetup={onOpenSchemeSetup} />

  return (
