#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/_audit-common.sh"

usage() {
  cat >&2 <<'EOF'
Usage: execute-pass-with-failover.sh
  --pass <name>
  --context <context>
  --prompt-bundle <file>
  --last-message-file <file>
  --provider <native-codex|antigravity|codex|google|github-copilot>
  --account <account>
  [--slot <slot>]
  --model <slug>
  --reasoning-effort <low|medium|high|xhigh>
  [--search 0|1]
  [--provider-mode <native-only|auto>]
exec
