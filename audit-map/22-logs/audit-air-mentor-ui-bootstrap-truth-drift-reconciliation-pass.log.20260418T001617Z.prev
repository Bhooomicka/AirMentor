/run/current-system/sw/bin/zsh -lc "python - <<'PY'
import pathlib, re, subprocess
root = pathlib.Path('audit-map/29-status')
for p in sorted(root.glob('audit-*.status')):
    txt = p.read_text()
    state = re.search(r'"'^state=(.*)$'"', txt, re.M)
    pid = re.search(r'"'^pid=(.*)$'"', txt, re.M)
    spid = re.search(r'"'^execution_supervisor_pid=(.*)$'"', txt, re.M)
    if not state or state.group(1) "'!= '"'running':
        continue
    vals=[]
    for name,m in [('pid',pid),('spid',spid)]:
        v = (m.group(1).strip() if m else '')
        if v:
            rc = subprocess.run(['ps','-p',v,'-o','pid='], capture_output=True, text=True)
            alive = bool(rc.stdout.strip())
        else:
            alive = False
        vals.append(f'{name}={v or \"<empty>\"}:{\"alive\" if alive else \"dead\"}')
    print(f'RUNNING_PID_CHECK\\t{p}\\t'+'\\t'.join(vals))
