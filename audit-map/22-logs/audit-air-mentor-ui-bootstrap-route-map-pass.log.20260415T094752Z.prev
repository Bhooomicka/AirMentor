                  eyebrow="Playback evidence"
                  maxHeight={300}
                >
                  {activeCheckpointEvidenceView === 'offerings'
                    ? selectedProofCheckpointDetail?.offeringRollups.length ? selectedProofCheckpointDetail.offeringRollups.slice(0, 8).map(item => {
