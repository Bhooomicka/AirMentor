  activeDiagnosticsQueueBurden,
  activeDiagnosticsUiParity,
  selectedProofCheckpoint,
  selectedProofCheckpointDetail,
  selectedProofCheckpointBlocked,
  selectedProofCheckpointHasBlockedProgression,

