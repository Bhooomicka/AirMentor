        <div style={{ display: 'flex', gap: 10, flexWrap: 'wrap' }}>
          <Btn onClick={onLogout}>Return to Login</Btn>
          <Btn variant="ghost" onClick={onBackToPortal}>Back to Portal</Btn>
        </div>
      </Card>
    </AcademicAuthPageShell>
  )
}

