{
  "name": "air-mentor-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "air-mentor-api"
  ],
  "scripts": {
    "dev": "vite",
    "dev:demo": "VITE_AIRMENTOR_API_BASE_URL= vite",
    "dev:live": "bash scripts/dev-live.sh",
    "dev:local-backend": "VITE_AIRMENTOR_API_BASE_URL=http://127.0.0.1:4000 npm run dev",
    "dev:live-with-fallback": "VITE_AIRMENTOR_API_BASE_URL=https://api-production-ab72.up.railway.app VITE_AIRMENTOR_API_FALLBACK_BASE_URLS=http://127.0.0.1:4000 npm run dev",
    "backend:dev:seeded": "bash scripts/run-local-backend-for-testing.sh",
    "backend:autostart:setup": "bash scripts/setup-local-backend-autostart.sh",
    "backend:autostart:disable": "bash scripts/disable-local-backend-autostart.sh",
    "backend:sync:railway-db": "bash scripts/sync-local-backend-db-from-railway.sh",
    "backend:drift:check": "bash scripts/check-local-railway-db-alignment.sh",
    "build:api": "npm --workspace air-mentor-api run build",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "inventory:compat-routes": "node scripts/report-compat-route-callers.mjs",
    "test:api": "npm --workspace air-mentor-api test",
    "evaluate:proof-risk-model": "npm --workspace air-mentor-api run evaluate:proof-risk-model",
    "verify:proof-closure": "npm --workspace air-mentor-api run build && npm run build && npm --workspace air-mentor-api test -- --reporter=dot && npm test -- --reporter=dot && bash scripts/playwright-admin-live-proof-risk-smoke.sh",
    "verify:proof-closure:proof-rc": "npm run verify:proof-closure && npm --workspace air-mentor-api run test:proof-rc",
    "verify:proof-closure:live": "AIRMENTOR_LIVE_STACK=1 bash scripts/playwright-admin-live-proof-risk-smoke.sh",
    "verify:proof-closure:teaching-live": "AIRMENTOR_LIVE_STACK=1 AIRMENTOR_PROOF_COVERAGE_TARGET=teacher bash scripts/playwright-admin-live-proof-risk-smoke.sh",
    "verify:final-closeout": "bash scripts/verify-final-closeout.sh",
    "verify:final-closeout:live": "bash scripts/verify-final-closeout-live.sh",
    "diagnostics:all": "npx tsc -p tsconfig.app.json --noEmit || true; npx tsc -p tsconfig.node.json --noEmit || true; npx tsc -p tests/tsconfig.json --noEmit || true; npx tsc -p air-mentor-api/tsconfig.json --noEmit || true; npm run -s lint || true",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:api": "playwright test tests/e2e/api-health.spec.ts --project=chromium",
    "preview": "vite preview",
    "playwright:install": "playwright install --with-deps",
    "playwright:version": "nix develop -c playwright --version",
    "playwright:smoke": "bash scripts/playwright-smoke.sh",
    "playwright:firefox:acceptance": "bash scripts/playwright-firefox-acceptance.sh",
    "playwright:admin-live:acceptance": "bash scripts/playwright-admin-live-acceptance.sh",
    "playwright:admin-live:accessibility-regression": "bash scripts/playwright-admin-live-accessibility-regression.sh",
    "playwright:admin-live:keyboard-regression": "bash scripts/playwright-admin-live-keyboard-regression.sh",
    "playwright:admin-live:proof-risk": "bash scripts/playwright-admin-live-proof-risk-smoke.sh",
    "playwright:admin-live:teacher-proof": "AIRMENTOR_PROOF_COVERAGE_TARGET=teacher bash scripts/playwright-admin-live-proof-risk-smoke.sh",
    "playwright:admin-live:request-flow": "bash scripts/playwright-admin-live-request-flow.sh",
    "playwright:admin-live:session-security": "bash scripts/playwright-admin-live-session-security.sh",
    "playwright:admin-live:teaching-parity": "bash scripts/playwright-admin-live-teaching-parity.sh"
  },
  "dependencies": {
    "framer-motion": "^12.35.2",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "axe-core": "^4.11.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
